<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sửa Thông Tin Sản Phẩm</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="bg-light text-dark">
    <div class="container mt-5 mb-5" style="max-width: 600px;">

        <% if (locals.error) { %>
            <div class="alert alert-danger alert-dismissible fade show rounded-1 shadow-sm" role="alert">
                <%= error %>
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
            <% } %>

                <div class="mb-4">
                    <a href="/products" class="text-decoration-none text-muted small">&larr; Quay lại danh sách</a>
                    <h3 class="mt-2 fw-bold">Cập Nhật Sản Phẩm</h3>
                </div>

                <div class="card shadow-sm border-0 rounded-1">
                    <div class="card-body p-4">
                        <form action="/products/edit/<%= product.id %>" method="POST" enctype="multipart/form-data">
                            <div class="mb-3">
                                <label class="form-label fw-medium text-secondary small text-uppercase">Tên Sản Phẩm <span class="text-danger">*</span></label>
                                <input type="text" name="name" class="form-control rounded-1" value="<%= product.name %>" required>
                            </div>

                            <div class="row mb-3">
                                <div class="col-md-6">
                                    <label class="form-label fw-medium text-secondary small text-uppercase">Giá (VNĐ) <span class="text-danger">*</span></label>
                                    <input type="number" name="price" class="form-control rounded-1" value="<%= product.price %>" required min="0">
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-medium text-secondary small text-uppercase">Tồn Kho <span class="text-danger">*</span></label>
                                    <input type="number" name="unit_in_stock" class="form-control rounded-1" value="<%= product.unit_in_stock %>" required min="0">
                                </div>
                            </div>

                            <div class="mb-4">
                                <label class="form-label fw-medium text-secondary small text-uppercase">Hình Ảnh Hiện Tại</label>
                                <div class="mb-2">
                                    <% if (product.url_image) { %>
                                        <img src="<%= product.url_image %>" id="currentImage" alt="<%= product.name %>" class="img-thumbnail rounded-1 border border-warning" style="max-height: 120px; object-fit: contain;">
                                        <% } else { %>
                                            <div id="noImageText" class="text-muted small italic">Chưa có hình ảnh</div>
                                            <% } %>
                                </div>
                                <label class="form-label fw-medium text-secondary small text-uppercase mt-3">Tải Lên Ảnh Mới</label>
                                <input type="file" name="image" id="imageInputEdit" class="form-control rounded-1 border-warning focus-ring-warning" accept="image/*">
                                <small class="text-muted d-block mt-1">Bỏ trống nếu không muốn thay đổi ảnh.</small>
                                <div class="mt-3 text-center">
                                    <img id="imagePreviewEdit" src="" alt="Preview" class="img-thumbnail rounded-1 border border-warning d-none" style="max-height: 200px; object-fit: contain;">
                                </div>
                            </div>

                            <div class="d-grid mt-4 pt-2 border-top">
                                <button type="submit" class="btn btn-warning fw-bold rounded-1 py-2 mt-3">Lưu Thay Đổi</button>
                            </div>
                        </form>
                    </div>
                </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.getElementById('imageInputEdit').addEventListener('change', function(event) {
            const file = event.target.files[0];
            const preview = document.getElementById('imagePreviewEdit');
            const noImgText = document.getElementById('noImageText');

            if (file) {
                preview.src = URL.createObjectURL(file);
                preview.classList.remove('d-none');
                if (noImgText) noImgText.classList.add('d-none');
            } else {
                preview.src = "";
                preview.classList.add('d-none');
                if (noImgText) noImgText.classList.remove('d-none');
            }
        });
    </script>
</body>

</html>