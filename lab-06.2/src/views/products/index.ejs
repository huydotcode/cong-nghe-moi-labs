<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Danh Sách Sản Phẩm</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="bg-light text-dark">
    <div class="container mt-5 mb-5">

        <% if (locals.success) { %>
            <div class="alert alert-success alert-dismissible fade show rounded-1 shadow-sm" role="alert">
                <%= success %>
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
            <% } %>

                <% if (locals.error) { %>
                    <div class="alert alert-danger alert-dismissible fade show rounded-1 shadow-sm" role="alert">
                        <%= error %>
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                    <% } %>

                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <h2 class="mb-0 fw-bold">Sản phẩm</h2>

                            <form action="/products" method="GET" class="d-flex w-50 justify-content-end px-3">
                                <div class="input-group" style="max-width: 350px;">
                                    <input type="text" name="search" class="form-control border-warning rounded-start-1" placeholder="Tìm tên sản phẩm..." value="<%= locals.search || '' %>">
                                    <button class="btn btn-warning rounded-end-1 fw-medium" type="submit">Tìm kiếm</button>
                                </div>
                                <% if (locals.search) { %>
                                    <a href="/products" class="btn btn-outline-secondary ms-2 rounded-1">Xóa lọc</a>
                                    <% } %>
                            </form>

                            <a href="/products/create" class="btn btn-warning fw-medium rounded-1 px-4">Thêm Mới</a>
                        </div>

                        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 row-cols-xl-4 g-4">
                            <% if (products && products.length > 0) { %>
                                <% products.forEach(product => { %>
                                    <div class="col">
                                        <div class="card h-100 shadow-sm border-0 rounded-2 border-bottom border-warning border-3">
                                            <% if (product.url_image) { %>
                                                <img src="<%= product.url_image %>" class="card-img-top rounded-top-2 p-3" alt="<%= product.name %>" style="height: 200px; object-fit: contain; background-color: #fff;">
                                                <% } else { %>
                                                    <div class="card-img-top bg-secondary bg-opacity-10 d-flex align-items-center justify-content-center rounded-top-2" style="height: 200px;">
                                                        <span class="text-muted small">No Img</span>
                                                    </div>
                                                    <% } %>

                                                        <div class="card-body">
                                                            <h5 class="card-title fw-bold text-truncate mb-1">
                                                                <%= product.name %>
                                                            </h5>
                                                            <p class="card-text text-danger fs-5 fw-semibold mb-2">
                                                                <%= product.price.toLocaleString() %> đ</p>
                                                            <p class="card-text text-muted small mb-0">Tồn kho: <span class="fw-medium text-dark"><%= product.unit_in_stock %></span></p>
                                                        </div>

                                                        <div class="card-footer bg-white border-top-0 pt-0 pb-3">
                                                            <div class="d-flex justify-content-between gap-2">
                                                                <a href="/products/<%= product.id %>" class="btn btn-sm btn-outline-secondary w-100 rounded-1">Xem</a>
                                                                <a href="/products/edit/<%= product.id %>" class="btn btn-sm btn-warning w-100 rounded-1">Sửa</a>
                                                                <form action="/products/delete/<%= product.id %>" method="POST" class="d-inline w-100" onsubmit="return confirm('Bạn có chắc chắn muốn xóa sản phẩm này?');">
                                                                    <button type="submit" class="btn btn-sm btn-danger w-100 rounded-1">Xóa</button>
                                                                </form>
                                                            </div>
                                                        </div>
                                        </div>
                                    </div>
                                    <% }) %>
                                        <% } else { %>
                                            <div class="col-12 text-center py-5 text-muted">
                                                <p class="fs-5">Không có sản phẩm nào.</p>
                                            </div>
                                            <% } %>
                        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>